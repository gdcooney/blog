---
import IconEdit from "@/assets/icons/IconEdit.svg";
import { SITE } from "@/config";

export interface Props {
  hideEditPost?: boolean;
  class?: string;
  post: {
    id: string;
    log_date: string;
  };
}

const { hideEditPost, post, class: className = "" } = Astro.props;

/** * We point the edit link back to your Cockpit/Lab.
 * Adjust this URL to match your local or production Lab address.
 */
const labBaseUrl = "https://lab.proveitsme.io"; 
const href = `${labBaseUrl}/?date=${post.log_date}`;

const showEditPost =
  SITE.editPost.enabled && !hideEditPost && href.trim() !== "";
---

{
  showEditPost && (
    <div class:list={["opacity-80", className]}>
      <span aria-hidden="true" class="max-sm:hidden">
        |
      </span>
      <a
        class="space-x-1.5 hover:opacity-75"
        href={href}
        rel="noopener noreferrer"
      >
        <IconEdit class="inline-block size-6" />
        <span class="italic max-sm:text-sm sm:inline">
          {SITE.editPost.text}
        </span>
      </a>
    </div>
  )
}
