---
interface Props {
  sprint: {
    sprint_number: number;
    title: string | null;
    focus_area: string | null;
    start_date: string;
    end_date: string;
  };
}
const { sprint } = Astro.props;

const today = new Date();
// Use date-only arithmetic to avoid timezone shifts
const start = new Date(sprint.start_date + "T00:00:00");
const end = new Date(sprint.end_date + "T00:00:00");
const msPerDay = 86400000;
const dayNumber = Math.floor((today.getTime() - start.getTime()) / msPerDay) + 1;
const totalDays = Math.floor((end.getTime() - start.getTime()) / msPerDay) + 1;
const progress = Math.min(100, Math.max(0, (dayNumber / totalDays) * 100));
const sprintName = sprint.title || sprint.focus_area || `Sprint ${sprint.sprint_number}`;
---

<div class="sprint-card">
  <p class="sprint-card__label">SPRINT {sprint.sprint_number}</p>
  <p class="sprint-card__name">{sprintName}</p>
  <div
    class="sprint-card__bar"
    role="progressbar"
    aria-valuenow={Math.max(1, dayNumber)}
    aria-valuemin={1}
    aria-valuemax={totalDays}
    aria-label={`Sprint progress: day ${dayNumber} of ${totalDays}`}
  >
    <div class="sprint-card__fill" style={`width: ${progress}%`}></div>
  </div>
  <p class="sprint-card__days">Day {Math.max(1, dayNumber)} of {totalDays}</p>
</div>

<style>
  .sprint-card {
    background: color-mix(in srgb, currentColor 4%, transparent);
    border: 0.5px solid color-mix(in srgb, currentColor 12%, transparent);
    border-radius: 10px;
    padding: 16px 20px;
    min-width: 176px;
    max-width: 220px;
  }
  .sprint-card__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 4px;
    font-family: ui-monospace, monospace;
  }
  .sprint-card__name {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 14px;
    line-height: 1.3;
  }
  .sprint-card__bar {
    height: 3px;
    background: color-mix(in srgb, currentColor 12%, transparent);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .sprint-card__fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.4s ease;
  }
  .sprint-card__days {
    font-size: 11px;
    opacity: 0.55;
    margin: 0;
    font-family: ui-monospace, monospace;
  }
</style>
