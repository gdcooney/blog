---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { supabase } from "../lib/supabase";

// Force SSR mode so we fetch fresh from the DB [cite: 64]
export const prerender = false; 

// Fetch your published logs from HQ [cite: 65]
const { data: logs } = await supabase
  .from("ms_daily_logs")
  .select("log_date, mood_score, journal_content")
  .eq("is_published", true)
  .order("log_date", { ascending: false });
---

<Layout>
  <main id="main-content" class="max-w-3xl mx-auto px-4 py-12">
    <section id="hero" class="mb-12">
      <h1 class="text-4xl font-black italic uppercase tracking-tighter">The Proof</h1>
      <p class="text-zinc-500 mt-2 italic">No theory. Just the work. [cite: 66, 67]</p>
    </section>

    <ul class="space-y-12">
      {logs && logs.length > 0 ? (
        logs.map((log) => (
          <li class="border-t border-zinc-800 pt-8">
            <div class="flex justify-between items-baseline mb-2">
              <a href={`/log/${log.log_date}`} class="text-2xl font-bold hover:text-orange-500 transition-colors">
                {log.log_date} [cite: 68]
              </a>
              <span class="text-sm font-mono text-zinc-500">MOOD: {log.mood_score}/5 [cite: 69]</span>
            </div>
            <div class="prose prose-invert line-clamp-2 text-zinc-400" set:html={log.journal_content} />
          </li>
        ))
      ) : (
        <p class="text-zinc-600 italic text-center py-20 border-2 border-dashed border-zinc-900 rounded-lg">
          HQ connection active. Waiting for the first synced log... [cite: 69, 70]
        </p>
      )}
    </ul>
  </main>
  <Footer />
</Layout>
