---
import { supabase } from "@/lib/supabase.js";
import SiteHeader from "@/components/SiteHeader.astro";
import AthleteHeader from "@/components/AthleteHeader.astro";
import JournalEntry from "@/components/JournalEntry.astro";
import type { AnnotationFeedback, Annotation } from "@/components/CoachAnnotation.astro";

export const prerender = false;

interface LogRow {
  id: string;
  log_date: string;
  journal_content: string | null;
  mood_score: number | null;
  ms_annotations?: Annotation[] | null;
}


const { username } = Astro.params;

// 1. Fetch profile with all blog fields
const { data: profile, error: profileError } = await supabase
  .from("ms_profiles")
  .select(
    "id, display_name, username, about_me, avatar_url, blog_accent_color, blog_font, blog_bg, social_links, blog_enabled, display_avatar, display_links"
  )
  .ilike("username", username ?? "")
  .single();

// 404 if not found or blog disabled
if (profileError || !profile || profile.blog_enabled === false) {
  return new Response(null, { status: 404 });
}

// 2. Fetch active sprint and published logs in parallel
const today = new Date().toISOString().split("T")[0];

const [sprintResult, logsResult] = await Promise.all([
  supabase
    .from("ms_sprints")
    .select("id, sprint_number, title, focus_area, start_date, end_date")
    .eq("user_id", profile.id)
    .lte("start_date", today)
    .gte("end_date", today)
    .limit(1)
    .maybeSingle(),
  supabase
    .from("ms_daily_logs")
    .select(
      `id, log_date, journal_content, mood_score,
       ms_annotations(
         id, author_type, author_role, content, persona_id,
         ms_persona_registry!ms_annotations_persona_id_fkey(display_name, specialty)
       )`
    )
    .eq("user_id", profile.id)
    .eq("is_published", true)
    .order("log_date", { ascending: false }),
]);

const sprint = sprintResult.data ?? null;
const logs = (logsResult.data ?? []) as LogRow[];

// 3. Batch-fetch annotation feedback for all annotations in one query
const allAnnotationIds = logs.flatMap((l: LogRow) =>
  (l.ms_annotations ?? []).map((a) => a.id)
);

let feedbackMap: Record<string, AnnotationFeedback> = {};
if (allAnnotationIds.length > 0) {
  const { data: feedbackRows } = await supabase
    .from("ms_annotation_feedback")
    .select("annotation_id, signal, reason_text")
    .eq("profile_id", profile.id)
    .in("annotation_id", allAnnotationIds)
    .order("created_at", { ascending: false });

  if (feedbackRows) {
    for (const row of feedbackRows) {
      // Keep only the most recent signal per annotation (rows are desc by created_at)
      if (!feedbackMap[row.annotation_id]) {
        feedbackMap[row.annotation_id] = {
          signal: row.signal,
          reason_text: row.reason_text,
        };
      }
    }
  }
}

// 4. Compute day numbers (oldest log = day 1, newest = day N)
const totalEntries = logs.length;

// 5. Derive CSS vars from profile
const accentColor = profile.blog_accent_color ?? "#D85A30";
const bgMap: Record<string, string> = {
  light: "#ffffff",
  warm: "#FAF8F4",
  dark: "#1A1917",
};
const fgMap: Record<string, string> = {
  light: "#1A1917",
  warm: "#1A1917",
  dark: "#F5F3EF",
};
const blogBg = profile.blog_bg ?? "light";
const bgColor = bgMap[blogBg] ?? bgMap.light;
const fgColor = fgMap[blogBg] ?? fgMap.light;
const fontFamily =
  profile.blog_font === "sans"
    ? "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    : "Georgia, 'Times New Roman', 'Palatino Linotype', Palatino, serif";

const canonicalURL = new URL(
  `/${profile.username}`,
  "https://blog.proveitsme.io"
).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: `${profile.display_name}'s Chronicle`,
  url: canonicalURL,
  author: { "@type": "Person", name: profile.display_name },
};

const pageTitle = `${profile.display_name}'s Chronicle — proveitsme.io`;
const pageDesc =
  profile.about_me ?? `${profile.display_name}'s personal chronicle.`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonicalURL} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body
    style={`--accent: ${accentColor}; background: ${bgColor}; color: ${fgColor}; font-family: ${fontFamily};`}
  >
    <SiteHeader username={profile.username} />

    <AthleteHeader profile={profile} sprint={sprint} />

    <main class="chronicle-main">
      <div class="chronicle-feed">
        {
          logs.length > 0 ? (
            logs.map((log: LogRow, index: number) => {
              // day 1 = oldest entry, day N = newest
              const dayNumber = totalEntries - index;
              return (
                <JournalEntry
                  log={log}
                  dayNumber={dayNumber}
                  displayName={profile.display_name}
                  feedbackMap={feedbackMap}
                />
              );
            })
          ) : (
            <p class="chronicle-empty">No published entries yet.</p>
          )
        }
      </div>
    </main>

    <footer class="chronicle-footer">
      <div class="chronicle-footer__inner">
        <span>blog.proveitsme.io/{profile.username}</span>
      </div>
    </footer>
  </body>
</html>

<style>
  .chronicle-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .chronicle-feed {
    padding-top: 8px;
  }
  .chronicle-empty {
    padding: 48px 0;
    text-align: center;
    opacity: 0.4;
    font-size: 14px;
  }
  .chronicle-footer {
    border-top: 0.5px solid color-mix(in srgb, currentColor 12%, transparent);
    margin-top: 16px;
  }
  .chronicle-footer__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 24px;
    font-size: 12px;
    opacity: 0.35;
    font-family: ui-monospace, monospace;
  }
</style>
